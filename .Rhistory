# Gerekli kütüphaneler
library(ggplot2)
library(readxl)
library(dplyr)
# Veriyi oku
veri <- read_xlsx("C:/Users/DELL/Desktop/Kategorik_S.xlsx")
# NA değerleri filtrele (ilgili değişkenlerde)
veri <- veri %>%
filter(
!is.na(`Yapay Zeka Kullanım Sıklığı`),
!is.na(`Stress Düzeyi`),
!is.na(`Cinsiyetiniz:`)
)
# Faktör sıralaması
veri$`Yapay Zeka Kullanım Sıklığı` <- factor(veri$`Yapay Zeka Kullanım Sıklığı`, levels = c("Az", "Orta", "Çok"))
veri$`Stress Düzeyi` <- factor(veri$`Stress Düzeyi`, levels = c("Düşük", "Orta", "Yüksek"))
# Nude/turuncu tonlu renk paleti
nude_colors <- c("#E3B7A0", "#F4CDA5", "#D1A684")  # Düşük, Orta, Yüksek için 3 ton
# Grafik
ggplot(veri, aes(x = `Yapay Zeka Kullanım Sıklığı`, fill = `Stress Düzeyi`)) +
geom_bar(position = "dodge") +
facet_wrap(~ `Cinsiyetiniz:`) +
scale_fill_manual(values = nude_colors) +
labs(
title = "Yapay Zeka Kullanım Sıklığına Göre Stres Düzeyleri",
x = "Yapay Zeka Kullanım Sıklığı",
y = "Kişi Sayısı",
fill = "Stres Düzeyi"
) +
theme_classic() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
strip.text = element_text(face = "bold"),
axis.text.x = element_text(angle = 45, hjust = 1)
)

library(ggplot2)
library(readxl)
library(dplyr)
# İlgili değişkenlerde NA değerleri çıkar
veri <- veri %>%
filter(
!is.na(`Cinsiyetiniz:`),
!is.na(`Yaş Aralığınız`),
!is.na(`Yapay zeka araçlarını kullandınız mı?`),
!is.na(`Haftalık kullanım sıklığı`),
!is.na(`Yapay zekanın akademik başarıya etkisi`),
!is.na(`Etik açıdan sakıncalı mı?`)
)
pie_chart <- function(data, var, title) {
# Değişkenin frekansını hesapla
df <- data %>%
count(!!sym(var)) %>%
mutate(prop = n / sum(n) * 100,
label = paste0(round(prop, 1), "%"))
ggplot(df, aes(x = "", y = prop, fill = !!sym(var))) +
geom_col(width = 1, color = "white") +
coord_polar(theta = "y") +
geom_text(aes(label = label), position = position_stack(vjust = 0.5), size = 4) +
labs(title = title, fill = var) +
theme_void() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold")
)
}
# Cinsiyetiniz
pie_chart(veri, "Cinsiyetiniz", "Cinsiyet Dağılımı")
# Yaş Aralığınız
pie_chart(veri, "Yaş Aralığınız", "Yaş Aralığı Dağılımı")
# Yapay zeka araçlarını kullandınız mı?
pie_chart(veri, "Yapay zeka araçlarını kullandınız mı?", "Yapay Zeka Araç Kullanımı")
# Haftalık kullanım sıklığı
pie_chart(veri, "Haftalık kullanım sıklığı", "Haftalık Yapay Zeka Kullanım Sıklığı")
# Yapay zekanın akademik başarıya etkisi
pie_chart(veri, "Yapay zekanın akademik başarıya etkisi", "Yapay Zekanın Akademik Başarıya Etkisi")
# Etik açıdan sakıncalı mı?
pie_chart(veri, "Etik açıdan sakıncalı mı?", "Yapay Zekanın Etik Açıdan Değerlendirilmesi")
# İlgili değişkenlerde NA değerleri çıkar
veri <- veri %>%
filter(
!is.na(`Cinsiyetiniz:`),
!is.na(`Yaş Aralığınızı Seçiniz.`),
!is.na(`Generatif yapay zeka araçlarını (ChatGPT, Copilot, Gemini vb.) hiç kullandınız mı?`),
!is.na(`Yapay Zeka Kullanım Sıklığı`),
!is.na(`Genel akademik ortalamanız:`),
!is.na(`Etik açıdan sakıncalı mı?`)
)
# İlgili değişkenlerde NA değerleri çıkar
veri <- veri %>%
filter(
!is.na(`Cinsiyetiniz:`),
!is.na(`Yaş Aralığınızı Seçiniz.`),
!is.na(`Generatif yapay zeka araçlarını (ChatGPT, Copilot, Gemini vb.) hiç kullandınız mı?`),
!is.na(`Yapay Zeka Kullanım Sıklığı`),
!is.na(`Genel akademik ortalamanız:`),
)
pie_chart <- function(data, var, title) {
# Değişkenin frekansını hesapla
df <- data %>%
count(!!sym(var)) %>%
mutate(prop = n / sum(n) * 100,
label = paste0(round(prop, 1), "%"))
ggplot(df, aes(x = "", y = prop, fill = !!sym(var))) +
geom_col(width = 1, color = "white") +
coord_polar(theta = "y") +
geom_text(aes(label = label), position = position_stack(vjust = 0.5), size = 4) +
labs(title = title, fill = var) +
theme_void() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold")
)
}
# Cinsiyetiniz
pie_chart(veri, "Cinsiyetiniz", "Cinsiyet Dağılımı")
# Cinsiyetiniz
pie_chart(veri, "Cinsiyetiniz:", "Cinsiyet Dağılımı")
# Yaş Aralığınız
pie_chart(veri, "Yaş Aralığınız", "Yaş Aralığı Dağılımı")
# Yaş Aralığınız
pie_chart(veri, "Yaş Aralığınızı Seçiniz.", "Yaş Aralığı Dağılımı")
# Cinsiyetiniz
pie_chart(veri, "Cinsiyetiniz:", "Cinsiyet Dağılımı")
# Yaş Aralığınız
pie_chart(veri, "Yaş Aralığınızı Seçiniz.", "Yaş Aralığı Dağılımı")
# Yapay zeka araçlarını kullandınız mı?
pie_chart(veri, "Generatif yapay zeka araçlarını (ChatGPT, Copilot, Gemini vb.) hiç kullandınız mı?", "Yapay Zeka Araç Kullanımı")

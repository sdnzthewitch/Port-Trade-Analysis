# 2018 ve 2024 verilerini filtrele ve büyüme oranını hesapla
growth_data <- data_long %>%
filter(Year %in% c(2018, 2024)) %>%
group_by(Country, `Port Name`, Year) %>%
summarise(Value = sum(Value, na.rm = TRUE), .groups = "drop") %>%
pivot_wider(names_from = Year, values_from = Value) %>%
mutate(
growth_pct = (`2024` - `2018`) / `2018` * 100
)
# Koordinatları ekle
growth_data <- growth_data %>%
left_join(port_coords, by = c("Country", "Port Name"))
# Harita oluştur
map <- plot_ly(
data = growth_data,
type = "scattergeo",
mode = "markers",
lat = ~Latitude,
lon = ~Longitude,
text = ~paste(`Port Name`, "<br>Büyüme (%):", round(growth_pct, 2)),
marker = list(
size = 10,
color = ~growth_pct,
colorscale = "YlOrRd",
colorbar = list(title = "Büyüme (%)"),
line = list(width = 0.5, color = 'black')
)
) %>%
layout(
title = list(
text = "2018–2024 Arası Liman Ticaret Hacmi Büyüme Oranları",
x = 0.5,
y = 0.95,
font = list(size = 18)
),
geo = list(
scope = 'world',
projection = list(type = 'natural earth'),
showland = TRUE,
landcolor = 'rgb(217, 217, 217)',
subunitwidth = 1,
countrywidth = 1,
subunitcolor = 'rgb(255, 255, 255)',
countrycolor = 'rgb(255, 255, 255)'
)
)
map
library(ggplot2)
ggplot(economic_z, aes(x = Value_z, fill = `Port Name`)) +
geom_density(alpha = 0.7, color = "black") +
facet_wrap(~ `Port Name`, scales = "free_y", ncol = 3) +  # her liman için ayrı panel
labs(
title = "2018–2024 Arası Limanların Standartlaştırılmış Ticaret Yoğunluğu",
subtitle = "Her limanın kendi dağılımı Z-score ile normalize edilmiştir",
x = "Z-score",
y = "Yoğunluk"
) +
theme_minimal(base_size = 13) +
theme(
legend.position = "none",
strip.text = element_text(face = "bold", size = 12),
plot.title = element_text(face = "bold", size = 16),
plot.subtitle = element_text(size = 12)
) +
scale_fill_brewer(palette = "Set3")
shapiro.test(economic_z$Value_z)  # Normal dağılım testi (genel)
# Alternatif olarak Kruskal-Wallis testi:
kruskal.test(Value_z ~ `Port Name`, data = economic_z)
kruskal.test(Value ~ `Port Name`, data = data_long)
# Gerekli kütüphane
install.packages("FSA")  # eğer yüklü değilse
library(FSA)
dunnTest(Value ~ `Port Name`, data = data_long, method = "bonferroni")
shapiro.test(economic_z$Value_z)  # Normal dağılım testi (genel)
# Alternatif olarak Kruskal-Wallis testi:
kruskal.test(Value_z ~ `Port Name`, data = economic_z)
kruskal.test(Value ~ `Port Name`, data = data_long)
library(FSA)
dunnTest(Value ~ `Port Name`, data = data_long, method = "bonferroni")
# Her liman için yıllık Z-score'lu değerleri al
# (Z-score zaten normalize olduğu için dağılım testi yapılabilir)
shapiro.test(economic_z$Value_z)  # Normal dağılım testi (genel)
# Perform Kruskal-Wallis test
kruskal_result <- kruskal.test(Value ~ `Port Name`, data = data_long)
# Extract H statistic, sample size n, and number of groups k
H <- kruskal_result$statistic
n <- length(data_long$Value)
k <- length(unique(data_long$`Port Name`))
# Calculate eta-squared effect size
eta_squared <- (H - k + 1) / (n - k)
print(paste("Eta-squared effect size:", round(eta_squared, 4)))
library(car)  # if not installed, run install.packages("car")
leveneTest(Value ~ `Port Name`, data = data_long)
pairwise.wilcox.test(data_long$Value, data_long$`Port Name`, p.adjust.method = "bonferroni")
library(dplyr)  # if not installed, run install.packages("dplyr")
desc_stats <- data_long %>%
group_by(`Port Name`) %>%
summarise(
n = n(),
mean = mean(Value),
median = median(Value),
sd = sd(Value),
IQR = IQR(Value)
)
print(desc_stats)
library(boot)  # if not installed, run install.packages("boot")
# Function to compute median
median_fun <- function(data, indices) {
return(median(data[indices]))
}
# Bootstrap CI for each Port Name
cis <- data_long %>%
group_by(`Port Name`) %>%
summarise(
median = median(Value),
lower_CI = {
boot_obj <- boot(Value, median_fun, R = 1000)
boot.ci(boot_obj, type = "perc")$percent[4]
},
upper_CI = {
boot_obj <- boot(Value, median_fun, R = 1000)
boot.ci(boot_obj, type = "perc")$percent[5]
}
)
print(cis)
library(ggplot2)
ggplot(data_long, aes(sample = Value)) +
stat_qq() +
stat_qq_line() +
facet_wrap(~ `Port Name`) +
ggtitle("QQ Plots of Value by Port Name")
# Gerekli kütüphaneleri yükle
library(ggplot2)
library(readr)   # read_csv için
library(dplyr)   # veri düzenleme için
# Veriyi CSV dosyasından oku (dosya adını kendi dosyanızla değiştirin)
veri <- readxl::read_xlsx("C:/Users/DELL/Desktop/Kategorik_S.xlsx")
# Veriyi gerekli şekilde faktörle (opsiyonel ama grafiklerde sıralama için yararlı olabilir)
veri$`Yapay Zeka Kullanım Sıklığı` <- factor(veri$`Yapay Zeka Kullanım Sıklığı`, levels = c("Az", "Orta", "Çok"))
veri$`Stress Düzeyi` <- factor(veri$`Stress Düzeyi`, levels = c("Düşük", "Orta", "Yüksek"))
# Facet ile bar grafik oluştur
ggplot(veri, aes(x = `Yapay Zeka Kullanım Sıklığı`, fill = `Stress Düzeyi`)) +
geom_bar(position = "dodge") +
facet_wrap(~ Cinsiyet) +
labs(
title = "Yapay Zeka Kullanım Sıklığına Göre Stres Düzeyleri",
x = "Yapay Zeka Kullanım Sıklığı",
y = "Kişi Sayısı",
fill = "Stress Düzeyi"
) +
theme_minimal()

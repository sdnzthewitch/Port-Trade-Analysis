pie_chart(veri, "Generatif yapay zeka araçlarını (ChatGPT, Copilot, Gemini vb.) hiç kullandınız mı?", "Yapay Zeka Araç Kullanımı")
# Haftalık kullanım sıklığı
pie_chart(veri, "Yapay Zeka Kullanım Sıklığı", "Haftalık Yapay Zeka Kullanım Sıklığı")
# Yapay zekanın akademik başarıya etkisi
pie_chart(veri, "Genel akademik ortalamanız:", "Akdamik Başarı Dağılımı")
if (!require(vcd)) install.packages("vcd")
library(vcd)
# İlgili değişkenleri faktör yap
veri_clean$`Yapay Zeka Kullanım Sıklığı` <- factor(veri_clean$`Yapay Zeka Kullanım Sıklığı`, levels = c("Az", "Orta", "Çok"))
veri_clean <- veri %>%
filter(
!is.na(`Yapay Zeka Kullanım Sıklığı`),
!is.na(`Stress Düzeyi`),
!is.na(`Cinsiyetiniz:`)
)
# İlgili değişkenleri faktör yap
veri_clean$`Yapay Zeka Kullanım Sıklığı` <- factor(veri_clean$`Yapay Zeka Kullanım Sıklığı`, levels = c("Az", "Orta", "Çok"))
veri_clean$`Stress Düzeyi` <- factor(veri_clean$`Stress Düzeyi`, levels = c("Düşük", "Orta", "Yüksek"))
veri_clean$`Cinsiyetiniz:` <- factor(veri_clean$`Cinsiyetiniz:`)
# Tablo oluştur (mozaik için)
tablo <- table(veri_clean$`Yapay Zeka Kullanım Sıklığı`, veri_clean$`Stress Düzeyi`, veri_clean$`Cinsiyetiniz:`)
# Mozaik grafik çiz (Cinsiyete göre facet gibi)
mosaic(tablo, shade = TRUE, legend = TRUE,
labeling_args = list(set_varnames = c("Kullanım Sıklığı", "Stress Düzeyi", "Cinsiyet")))
if(!require(ggmosaic)) install.packages("ggmosaic")
library(ggmosaic)
ggplot(data = veri_clean) +
geom_mosaic(aes(weight = 1, x = product(`Yapay Zeka Kullanım Sıklığı`), fill = `Stress Düzeyi`)) +
facet_wrap(~`Cinsiyetiniz:`) +
labs(title = "Mozaik Grafik: Yapay Zeka Kullanım Sıklığı ve Stres Düzeyi (Cinsiyete Göre)") +
theme_minimal()
